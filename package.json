{
  "name": "mediadownloader",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start":               "expo start",
    "android":             "expo start --android",
    "ios":                 "expo start --ios",
    "web":                 "expo start --web",
    "export:web":          "expo export --platform web",
    "desktop":             "npm run export:web && cd desktop && npm install && npm start",
    "build:desktop:mac":   "npm run export:web && cd desktop && npm install && npm run build:mac",
    "build:desktop:win":   "npm run export:web && cd desktop && npm install && npm run build:win",
    "build:desktop:linux": "npm run export:web && cd desktop && npm install && npm run build:linux"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/stack": "^7.8.5",
    "async-storage": "^0.1.0",
    "expo": "~55.0.6",
    "expo-av": "^16.0.8",
    "expo-file-system": "^55.0.10",
    "expo-linear-gradient": "^55.0.8",
    "expo-media-library": "^55.0.9",
    "expo-sharing": "^55.0.11",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "^4.23.0",
    "react-native-web": "^0.21.0"
  },
  "private": true
}
